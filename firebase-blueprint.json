{
  "entities": {
    "blog": {
      "title": "Blog Post",
      "description": "A blog post for the system-wide blog",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the blog post" },
        "slug": { "type": "string", "description": "The URL-friendly slug of the post" },
        "content": { "type": "string", "description": "The full content of the post in Markdown" },
        "excerpt": { "type": "string", "description": "A short summary of the post" },
        "coverImage": { "type": "string", "description": "URL to the cover image" },
        "metaTitle": { "type": "string", "description": "SEO meta title" },
        "metaDescription": { "type": "string", "description": "SEO meta description" },
        "status": { "type": "string", "enum": ["draft", "published"], "description": "Publishing status" },
        "authorId": { "type": "string", "description": "UID of the author" },
        "authorName": { "type": "string", "description": "Name of the author" },
        "tags": { "type": "array", "description": "List of tags for the post" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["title", "slug", "content", "status", "authorId", "createdAt"]
    },
    "teacher_attendance": {
      "title": "Teacher Attendance Record",
      "description": "An attendance record for a teacher",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string", "description": "ID of the teacher" },
        "teacherName": { "type": "string", "description": "Name of the teacher" },
        "date": { "type": "string", "description": "Date of attendance (YYYY-MM-DD)" },
        "status": { "type": "string", "enum": ["present", "absent", "late", "leave"], "description": "Attendance status" },
        "lateTime": { "type": "string", "description": "Time of arrival if late (HH:MM)" },
        "institutionId": { "type": "string", "description": "ID of the institution" },
        "markedBy": { "type": "string", "description": "UID of the person who marked the attendance" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["teacherId", "date", "status", "institutionId", "markedBy", "createdAt"]
    },
    "batch_content": {
      "title": "Batch Website Content",
      "description": "A post or update for a specific batch website",
      "type": "object",
      "properties": {
        "batchId": { "type": "string", "description": "ID of the batch" },
        "institutionId": { "type": "string", "description": "ID of the institution" },
        "title": { "type": "string", "description": "Title of the update" },
        "description": { "type": "string", "description": "Detailed description or homework details" },
        "contentType": { "type": "string", "enum": ["homework", "progress", "material", "notice"], "description": "Type of update" },
        "attachments": { "type": "array", "description": "List of links or resource URLs" },
        "publishDate": { "type": "string", "format": "date", "description": "Date to show for the update" },
        "authorId": { "type": "string", "description": "UID of the publisher" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["batchId", "institutionId", "title", "contentType", "publishDate", "createdAt"]
    },
    "exam_ai_config": {
      "title": "Exam AI Configuration",
      "description": "Rules and questions for AI-based paper evaluation",
      "type": "object",
      "properties": {
        "examId": { "type": "string", "description": "The linked offline exam ID" },
        "institutionId": { "type": "string", "description": "Owner institution ID" },
        "questions": {
          "type": "array",
          "description": "List of questions with grading logic",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "number": { "type": "string" },
              "text": { "type": "string" },
              "maxMarks": { "type": "number" },
              "expectedAnswer": { "type": "string" },
              "gradingRubric": { "type": "string", "description": "Bangla instructions for AI marks deduction" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["examId", "institutionId", "questions"]
    },
    "ai_evaluation": {
      "title": "AI Paper Evaluation",
      "description": "Results of an AI paper scan for a student",
      "type": "object",
      "properties": {
        "examId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "institutionId": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Base64 or Cloud Storage URLs of student paper" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "finalized"] },
        "analysis": {
          "type": "object",
          "properties": {
            "totalMarks": { "type": "number" },
            "feedback": { "type": "string", "description": "Overall feedback in Bangla" },
            "questionWise": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "questionId": { "type": "string" },
                  "marksObtained": { "type": "number" },
                  "mistakes": { "type": "string" },
                  "corrections": { "type": "string" }
                }
              }
            }
          }
        },
        "evaluatedBy": { "type": "string", "description": "UID of the teacher who reviewed/finalized" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["examId", "studentId", "institutionId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/blogs/{blogId}": {
      "schema": "blog",
      "description": "Collection of system-wide blog posts"
    },
    "/teacher_attendance/{attendanceId}": {
      "schema": "teacher_attendance",
      "description": "Collection of teacher attendance records"
    },
    "/batch_content/{contentId}": {
      "schema": "batch_content",
      "description": "Daily updates and materials for batch websites"
    },
    "/exam_ai_config/{configId}": {
      "schema": "exam_ai_config",
      "description": "AI configurations for exams"
    },
    "/ai_evaluations/{evalId}": {
      "schema": "ai_evaluation",
      "description": "AI-based paper scans and analysis"
    }
  }
}
